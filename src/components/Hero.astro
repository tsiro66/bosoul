---
interface Props {
  lang?: 'en' | 'el';
  title?: string;
  subtitle?: string;
  ctaText?: string;
  ctaLink?: string;
  badge?: string;
}

const { lang = 'en', title = 'BoSoul Therapy', subtitle = 'Restore balance through mindful movement, breathwork, and holistic body therapy in the heart of Athens.', ctaText, ctaLink = '#contact', badge } = Astro.props;

import { t, type Locale } from '@i18n/index';

const locale = lang as Locale;

const resolvedCtaText = ctaText ?? t(locale, 'hero.ctaText');
const resolvedBadge = badge ?? t(locale, 'hero.badge');
const resolvedAthensLabel = t(locale, 'hero.athensLabel');

import heroImage from '@assets/bosoul-hero.jpg';
---

<section class="fixed inset-0 z-0 overflow-hidden">

  <img
    src={heroImage.src}
    alt=""
    class="absolute inset-0 w-full h-full object-cover"
    loading="eager"
  />

  <div class="absolute inset-0 bg-black/40"></div>
  <div class="absolute inset-0 bg-gradient-to-r from-black/60 via-black/30 to-transparent"></div>

  <div class="relative z-10 mx-auto max-w-7xl px-6 lg:px-8 py-16 lg:py-0 lg:min-h-screen lg:flex lg:items-center">

    <div class="max-w-xl lg:max-w-lg">

      <span class="inline-block text-[10px] sm:text-xs font-medium uppercase tracking-[0.3em] text-amber-300/90 mb-8 lg:mb-10">
        {resolvedBadge}
      </span>

      <h1 class="font-serif text-4xl sm:text-5xl lg:text-6xl font-normal leading-[1.1] tracking-tight text-white">
        {title}
      </h1>

      <p class="mt-6 lg:mt-8 text-base sm:text-lg leading-relaxed text-white/80 max-w-md">
        {subtitle}
      </p>

      <div class="mt-10 lg:mt-12 flex flex-col sm:flex-row items-start sm:items-center gap-4">
        <a
          href={ctaLink}
          class="group inline-flex items-center gap-2 rounded-full bg-white px-8 py-3.5 text-sm font-medium tracking-wide text-zinc-900 transition-all duration-300 hover:-translate-y-1 hover:bg-amber-50 hover:shadow-[0_0_40px_-8px_rgba(255,255,255,0.25)]"
        >
          {resolvedCtaText}
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17.25 8.25L21 12m0 0l-3.75 3.75M21 12H3" />
          </svg>
        </a>
        <span class="text-xs tracking-widest uppercase text-white/60">{resolvedAthensLabel}</span>
      </div>

    </div>

  </div>

</section>

<style>
  h1 {
    font-family: var(--font-vollkorn);
  }
</style>
